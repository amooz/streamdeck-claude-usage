# Supply-chain hardening. See CONTRIBUTING.md for the rationale.

# Refuse to install package versions less than 7 days old. Defends against
# fresh malicious publishes that haven't been caught and yanked yet.
# Requires npm >= 11.
min-release-age=7

# Refuse to run install if Node/npm versions don't match `engines` in
# package.json. Stops the wrong-toolchain footgun (e.g. someone running
# npm 10 silently bypassing min-release-age).
engine-strict=true

# Fail audits at "moderate" or higher when running `npm audit`.
audit-level=moderate

# Save exact versions in package.json (no ^ or ~). Combined with package-lock.json
# integrity hashes, this gives reproducible, SHA-pinned installs.
save-exact=true
