{
	"name": "streamdeck-claude-usage",
	"version": "0.1.0",
	"description": "Stream Deck plugin that displays Claude usage statistics.",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=22.0.0",
		"npm": ">=11.0.0"
	},
	"scripts": {
		"build": "rollup -c && node scripts/sync-to-appdata.mjs",
		"watch": "rollup -c -w --watch.onEnd=\"node scripts/sync-to-appdata.mjs && node scripts/restart-plugin.mjs\"",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@elgato/cli": "1.7.4",
		"@eslint/js": "9.39.4",
		"@rollup/plugin-commonjs": "29.0.2",
		"@rollup/plugin-node-resolve": "16.0.3",
		"@rollup/plugin-terser": "1.0.0",
		"@rollup/plugin-typescript": "12.3.0",
		"@tsconfig/node20": "20.1.9",
		"@types/node": "20.19.41",
		"@typescript-eslint/eslint-plugin": "8.59.3",
		"@typescript-eslint/parser": "8.59.3",
		"@vitest/coverage-v8": "4.1.6",
		"eslint": "10.3.0",
		"globals": "17.6.0",
		"prettier": "3.8.3",
		"rollup": "4.60.3",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"vitest": "4.1.6"
	},
	"dependencies": {
		"@elgato/streamdeck": "2.1.0"
	}
}
